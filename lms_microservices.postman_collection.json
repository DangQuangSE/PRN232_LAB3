{
	"info": {
		"_postman_id": "8f828a2a-4a6c-48c9-9481-4279ab87c71d",
		"name": "PRN232 LMS Microservices API",
		"description": "Postman collection to test the refactored PRN232 LMS Microservices System through YARP API Gateway.",
